<% layout("/layouts/boilerplate") %>

<!-- Hero Section -->

<section class="hero-section">

    <div class="hero-overlay">

        <div class="hero-content">

            <h1>
                Explore The Beauty Of Gujarat
            </h1>

            <p>
                Discover Temples, Heritage,
                Culture & Tourism Places
            </p>

            <div class="mt-4">

                <a
                href="/temples"
                class="btn btn-dark btn-lg me-3">

                    Explore Temples

                </a>

                <a
                href="/temples/new"
                class="btn btn-warning btn-lg">

                    Add Temple

                </a>

            </div>

        </div>

    </div>

</section>

<!-- About Section -->

<section class="container py-5">

    <div class="row align-items-center">

        <div class="col-lg-6">

            <img
            src="https://gujarattourism.com/content/dam/gujrattourism/images/home_page/gt_banner.jpg"
            class="about-img">

        </div>

        <div class="col-lg-6">

            <h2 class="section-title">
                Welcome To Gujarat Tourism
            </h2>

            <p class="section-text">

                Gujarat is famous for its beautiful
                temples, culture, food, festivals,
                wildlife and heritage places.

            </p>

            <p class="section-text">

                Explore spiritual destinations and
                tourism places across Gujarat.

            </p>

        </div>

    </div>

</section>

<!-- Feature Cards -->

<section class="container pb-5">

    <h2 class="text-center section-title mb-5">

        Explore Gujarat

    </h2>

    <div class="row">

        <div class="col-md-4 mb-4">

            <div class="tour-card">

                <img
                src="https://www.tourmyindia.com/blog//wp-content/uploads/2023/01/Kalika-Mata-Temple-Gujarat.jpg">

                <div class="tour-body">

                    <h4>Famous Temples</h4>

                    <p>
                        Discover spiritual temples
                        across Gujarat.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="tour-card">

                <img
                src="https://www.girnationalpark.in/uploads/gir-jeep-booking.JPG"
                class="tour-img">

                <div class="tour-body">

                    <h4>Tourist Places</h4>

                    <p>
                        Explore beautiful tourism
                        destinations in Gujarat.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="tour-card">

                <img
                src="https://s7ap1.scene7.com/is/image/incredibleindia/gujrati-thali-dwarka-gujarat-blog-gas-hero?qlt=82&ts=1726734729642"
                class="tour-img">

                <div class="tour-body">

                    <h4>Gujarati Food</h4>

                    <p>
                        Taste delicious traditional
                        Gujarati dishes.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>